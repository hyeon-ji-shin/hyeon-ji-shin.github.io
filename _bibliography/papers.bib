@inproceedings{shin2024fer,
  abbr         = {KIBME},
  title        = {Race-Robust Deep Learning-Based Facial Expression Classification Technique},
  title_ko     = {인종에 강인한 딥러닝 기반의 표정 분류 기법},
  author       = {Park, Beom-Jun and Seo, Hae-hun and Shin, Hyeon-ji and Choi, In-kyu},
  author_ko    = {박범준, 서해훈, 신현지, 최인규},
  show_abstract = {false},
  abstract     = {},
  abstract_ko  = {본 논문은 사용자의 감정을 인식하기 위한 표정 분류 연구에서 특정 인종에 집중되는 경향을 극복하고자 한다. 다인종 국가인 대한민국의 상황을 고려하여, 한국인을 포함한 다양한 인종으로 구성된 테스트 데이터를 기반으로 인종에 강인한 얼굴 표정 인식 모델을 제안한다. 얼굴 검출을 위한 모델로 MTCNN을 사용하고 표정 분류를 위한 모델로 DAN을 사용한다. 학습데이터는 외국인으로, 테스트 데이터는 외국인과 한국인으로 구성해 실험을 진행하였다. 총 3가지로 구성된 테스트 데이터로 진행한 결과, 제안된 모델은 평균 91.25%의 높은 정확도를 기록하여, 다양한 인종에 대해 우수한 성능을 보여주는 것을 확인하였다.},
  booktitle    = {The Korean Institute of Broadcast and Media Engineers, Fall Conference},
  booktitle_ko = {한국방송·미디어공학회 추계학술대회},
  year         = {2024},
  paper        = {https://www.dbpia.co.kr/journal/articleDetail?nodeId=NODE11995397},
  selected     = {false},
  bibtex_show  = {true},
  category     = {false_per_mapping_navigation}
}

@inproceedings{shin2024lio,
  abbr         = {ICROS},
  title        = {Comparison of LiDAR-Inertial Odometry for GNSS-denied areas in Autonomous Vehicle},
  title_ko     = {자율주행에서의 GNSS 음영구역을 위한 LiDAR-Inertial Odometry 측정 비교},
  author       = {Shin, Hyeon-ji and Sagong, Eui-Hoon and Hwang, Myeon-Jung},
  author_ko    = {신현지, 사공의훈, 황면중},
  show_abstract = {false},
  abstract     = {This paper analyzes the performance of FAST-LIO-SAM[1]. The combination of FAST-LIO2[2] and LIO-SAM[3] enables fast, robust, and accurate LiDAR navigation and mapping through the use of an incremental KD-tree. Additionally, it achieves highly accurate, real-time trajectory estimation and mapping by incorporating loop closures. FAST-LIO2 and FAST-LIO-SAM are compared and analyzed through simulations that validate the application of LiDAR-Inertial Odometry for the GNSS(Global Navigation Satellite System)-denied areas. },
  booktitle    = {Institute of Control, Robotics and Systems (ICROS)},
  booktitle_ko = {제어로봇시스템학회 학술대회 (ICROS)},
  year         = {2024},
  paper        = {https://www.dbpia.co.kr/journal/articleDetail?nodeId=NODE11909238},
  selected     = {true},
  bibtex_show  = {true},
  category     = {true_calib_pe_sf_slam}
}